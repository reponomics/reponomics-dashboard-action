{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "package-name": "reponomics-dashboard-action",
      "release-type": "simple",
      "include-component-in-tag": false,
      "changelog-path": "CHANGELOG.md",
      "exclude-paths": [
        ".github/workflows/publish-template.yml",
        "scripts/build_template.py",
        "scripts/publish_generated_repo.py",
        "scripts/smoke_template_release.py",
        "scripts/template_consumer_e2e.py",
        "scripts/template_contract.py",
        "scripts/verify_workflow_classification.py",
        "template",
        "template-contract.yml",
        "template-manifest.yml",
        "tests/test_generated_repos.py",
        "tests/test_template_setup_acceptance.py"
      ],
      "extra-files": [
        {
          "type": "generic",
          "path": "pyproject.toml"
        },
        {
          "type": "generic",
          "path": "dashboard_action/run_modules/core.py"
        }
      ]
    },
    "template": {
      "package-name": "reponomics-dashboard",
      "release-type": "simple",
      "include-component-in-tag": true,
      "skip-changelog": true,
      "extra-files": [
        {
          "type": "yaml",
          "path": "template-contract.yml",
          "jsonpath": "$.template_version"
        }
      ]
    }
  }
}
